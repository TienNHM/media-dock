{
  "name": "media-dock",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": ["apps/web", "apps/desktop-shell"],
  "scripts": {
    "download:native-binaries": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-binaries.ps1",
    "dev:spa": "npm run start -w apps/web",
    "dev:electron": "npm run dev -w apps/desktop-shell",
    "build:spa-desktop": "npm run build -w apps/web",
    "build:spa-hosted": "npm run build:hosted -w apps/web",
    "package:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-desktop.ps1",
    "package:desktop:multi-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-desktop-matrix.ps1"
  }
}
