{
  "name": "media-dock",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/web",
    "apps/desktop-shell",
    "packages/*"
  ],
  "scripts": {
    "fetch:binaries": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-binaries.ps1",
    "web:dev": "npm --workspace web run start",
    "web:build": "npm --workspace web run build",
    "desktop:dev": "npm --workspace @mediadock/desktop-shell run dev",
    "desktop:build": "npm --workspace @mediadock/desktop-shell run build"
  }
}
